# config/MA/config.128_wAT_entsoe_MA.yaml

run:
  name: 128_wAT_entsoe_MA
  disable_progressbar: false
  shared_resources:
    policy: true #false
  shared_cutouts: true
scenario:
  simpl:
  - ''
  ll:
  - vopt
  clusters:
  - 128
  opts:
  - ''
  sector_opts:
  - ''
  planning_horizons:
  - ''
countries:
- AL
- AT
- BA
- BE
- BG
- CH
- CZ
- DE
- DK
- EE
- ES
- FI
- FR
- GB
- GR
- HR
- HU
- IE
- IT
- LT
- LU
- LV
- ME
- MD
- MK
- NL
- 'NO'
- PL
- PT
- RO
- RS
- SE
- SI
- SK
- UA
electricity:
  custom_powerplants: true
  co2limit: 95900000.0
  co2base: 1918000000.0
lines:
  reconnect_crimea: false
  under_construction: remove #keep
links:
  under_construction: remove #keep
transmission_projects:
  enable: true
  include:
    tyndp2020: false #true
    nep: false #true
    manual: false #true
  skip:
  - upgraded_lines
  - upgraded_links
  status:
  - under_construction
  - in_permitting
  - confirmed
  new_link_capacity: zero
enable:
  retrieve: true
  retrieve_databundle: true
  retrieve_cost_data: true
  retrieve_cutout: true
clustering:
  focus_weights:
    AT: 0.4
  simplify_network:
    to_substations: false #true #false ## true leads to error
    remove_stubs_across_borders: true #true
  cluster_network:
    algorithm: kmeans #hac #kmeans # trying hac for substations
    hac_features:
    - wnd100m
    - influx_direct
  temporal:
    resolution_elec: 6H #false # lower temporal resolution for testing
solving:
  solver:
    name: gurobi
    options: gurobi-default-threads #gurobi-default

  solver_options:
    ### trying more threads for speed
    gurobi-default-threads:
      threads: 20 #8
      method: 2 # barrier
      crossover: 0
      BarConvTol: 1.e-6
      Seed: 123
      AggFill: 0
      PreDual: 0
      GURO_PAR_BARDENSETHRESH: 200
    cplex-default:
      threads: 4
      lpmethod: 4 # barrier
      solutiontype: 2 # non basic solution, ie no crossover
      barrier.convergetol: 1.e-5
      feasopt.tolerance: 1.e-6
    copt-default:
      Threads: 8
      LpMethod: 2
      Crossover: 0
      RelGap: 1.e-6
      Dualize: 0
    copt-gpu:
      LpMethod: 6
      GPUMode: 1
      PDLPTol: 1.e-5
      Crossover: 0
    cbc-default: {} # Used in CI
    glpk-default: {} # Used in CI

  mem_mb: 30000 #memory in MB; 20 GB enough for 50+B+I+H2; 100 GB for 181+B+I+H2
  memory_logging_frequency: 30 # in seconds
  runtime: 6h #runtime in humanfriendly style https://humanfriendly.readthedocs.io/en/latest/

### additional parameters
austria_shapefiles:
  buses: "data/shapefiles/buses_aut.shp"
  lines: "data/shapefiles/lines_aut.shp"
output_network: "resources/networks/austria.nc"
case: "MA"

residual_loads:
  scenario: "NIP2030"   # or NIP2040 or entsoeAT
  input_dir: "data/MA/loads"
  inputs:
    nachfrage: "{input_dir}/{scenario}/Nachfrage.csv"
    pv: "{input_dir}/{scenario}/PV.csv"
    wind: "{input_dir}/{scenario}/Wind.csv"
    biomasse: "{input_dir}/{scenario}/biomasse.csv"
    gross_wasserkraft: "{input_dir}/{scenario}/GrossWasserkraft.csv"
    klein_wasserkraft: "{input_dir}/{scenario}/Kleinwasserkraft.csv"